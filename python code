import mysql.connector
from datetime import datetime, timedelta

class AirlineManagement:
    def __init__(self):
        try:
            self.conn = mysql.connector.connect(
            host='localhost',
            user='root',
            password='0000',
            database='airline_management'
        )
            self.cursor = self.conn.cursor()
        except mysql.connector.Error as err:
            print(f"Error: {err}")
            self.conn = None
            self.cursor = None
        

    def add_airline(self, flightid,name, code):
        """Add a new airline."""
        try:
            self.cursor.execute('INSERT INTO airlines (id,name, code) VALUES (%s,%s, %s)', (flightid,name, code))
            self.conn.commit()
            print("Airline added successfully.")
        except mysql.connector.Error as err:
            print(f"Error adding airline: {err}")

    def view_airlines(self):
        """View all airlines."""
        try:
            self.cursor.execute('SELECT * FROM airlines')
            airlines = self.cursor.fetchall()
            if airlines:
                print("All Airlines:")
                for airline in airlines:
                    print(airline)
            else:
                print("No airlines found.")
        except mysql.connector.Error as err:
            print(f"Error retrieving airlines: {err}")

    def update_airline(self, airline_id, name, code):
        """Update an airline's details."""
        try:
            self.cursor.execute('UPDATE airlines SET name=%s, code=%s WHERE id=%s', (name, code, airline_id))
            self.conn.commit()
            print("Airline updated successfully.")
        except mysql.connector.Error as err:
            print(f"Error updating airline: {err}")

    def delete_airline(self, airline_id):
        """Delete an airline."""
        try:
            self.cursor.execute('DELETE FROM airlines WHERE id=%s', (airline_id,))
            self.conn.commit()
            print("Airline deleted successfully.")
        except mysql.connector.Error as err:
            print(f"Error deleting airline: {err}")

    def search_airline(self, airline_id):
        """Search for an airline by ID."""
        try:
            self.cursor.execute('SELECT * FROM airlines WHERE id=%s', (airline_id,))
            airline = self.cursor.fetchone()
            if airline:
                print(f"Airline found: {airline}")
            else:
                print("No airline found with that ID.")
        except mysql.connector.Error as err:
            print(f"Error searching airline: {err}")

    def get_next_flight_available(self, airline_id):
        """Get the next available flight for a specific airline."""
        try:
            self.cursor.execute('SELECT * FROM flights WHERE airline_id=%s ORDER BY departure_time LIMIT 1', (airline_id,))
            flight = self.cursor.fetchone()
            if flight:
                print(f"Next available flight for Airline ID {airline_id}: {flight}")
            else:
                print("No flights available for this airline.")
        except mysql.connector.Error as err:
            print(f"Error retrieving next available flight: {err}")

    def generate_airline_summary_report(self, flight_id):
        """Generate a summary report of an airline's details."""
        try:
            self.cursor.execute('SELECT * FROM airlines WHERE id=%s', (flight_id,))
            airline = self.cursor.fetchone()
            if airline:
                print(f"Summary for Airline ID {flight_id}:")
                print(f"Name: {airline[1]}")
                print(f"Code: {airline[2]}")
                # Optionally, you can add more details like flight information
            else:
                print("No airline found with that ID.")
        except mysql.connector.Error as err:
            print(f"Error generating airline summary report: {err}")

    def close(self):
        """Close the database connection."""
        self.cursor.close()
        self.conn.close()






