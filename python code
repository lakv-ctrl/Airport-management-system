import mysql.connector
def setup_database():
    conn = mysql.connector.connect(host='localhost',user='root',password='0000',database='airline_management')
    cursor = conn.cursor()

    # Create tables    
    cursor.execute('''CREATE TABLE IF NOT EXISTS airlines (id INT AUTO_INCREMENT PRIMARY KEY,name VARCHAR(255) NOT NULL,code VARCHAR(10) NOT NULL)''')

    cursor.execute('''CREATE TABLE IF NOT EXISTS flights (id INT AUTO_INCREMENT PRIMARY KEY,flight_number VARCHAR(10) NOT NULL,departure VARCHAR(255) NOT NULL,arrival VARCHAR(255) NOT NULL,departure_time DATETIME NOT NULL,arrival_time DATETIME NOT NULL,airline_id INT,FOREIGN KEY (airline_id) REFERENCES airlines (id))''')

    cursor.execute('''CREATE TABLE IF NOT EXISTS passengers (id INT AUTO_INCREMENT PRIMARY KEY,flight_id INT,first_name VARCHAR(255),last_name VARCHAR(255),email VARCHAR(255),contact VARCHAR(255),FOREIGN KEY (flight_id) REFERENCES flights (id))''')
    conn.commit()
    cursor.close()
    conn.close()
setup_database()



#FLIGHT MANAGEMENT
class FlightManagement:
    def __init__(self):
        self.conn = mysql.connector.connect(host='localhost',user='root',password='0000',database='airline_management')
        self.cursor = self.conn.cursor()

    def add_flight(self, flight_number, departure, arrival, departure_time, arrival_time, airline_id):
        self.cursor.execute('''INSERT INTO flights (flight_number, departure, arrival, departure_time, arrival_time, airline_id)VALUES (%s, %s, %s, %s, %s, %s);''', (flight_number, departure, arrival, departure_time, arrival_time, airline_id))
        self.conn.commit()

    def view_flights(self):
        try:
            self.cursor.execute('SELECT * FROM flights')
            for row in self.cursor.fetchall():
                print(row)
        except mysql.connector.Error as err:
            print(f"Error retrieving flights: {err}")

    def update_flight(self, flight_id, flight_number, departure, arrival, departure_time, arrival_time):
        try:
            self.cursor.execute('''UPDATE flights SET flight_number=%s, departure=%s, arrival=%s, departure_time=%s, arrival_time=%sWHERE id=%s''', (flight_number, departure, arrival, departure_time, arrival_time, flight_id))
            self.conn.commit()
        except mysql.connector.Error as err:
