#PASSENGER MANAGEMENT
class PassengerManagement:
    def __init__(self):
        try:
            self.conn = mysql.connector.connect(
            host='localhost',
            user='root',
            password='0000',
            database='airline_management'
        )
            self.cursor = self.conn.cursor()
        except mysql.connector.Error as err:
            print(f"Error: {err}")
            self.conn = None
            self.cursor = None
            

    def add_passenger(self, passenger_id,first_name, last_name, email, contact, flight_id):
        """Add a new passenger to a flight."""
        try:
            self.cursor.execute('''INSERT INTO passengers (id,first_name, last_name, email, contact, flight_id)VALUES (%s,%s,%s, %s, %s, %s)''', (passenger_id,first_name, last_name, email, contact, flight_id))
            self.conn.commit()
        except mysql.connector.Error as err:
            print(f"Error adding passenger: {err}")


    def view_passenger(self):
        """View all passengers."""
        try:
            self.cursor.execute('SELECT * FROM passengers')
            passengers = self.cursor.fetchall()
            for passenger in passengers:
                print(passenger)
        except mysql.connector.Error as err:
            print(f"Error retrieving passengers: {err}")
        

    def update_passenger(self, first_name, last_name, email, contact, flight_id,passenger_id):
        """Update details of an existing passenger."""
        try:
            self.cursor.execute('''UPDATE passengers SET first_name=%s, last_name=%s, email=%s, contact=%s, flight_id =%sWHERE id=%s''', (first_name, last_name, email, contact, flight_id,passenger_id))
            self.conn.commit()
            print(f"Passenger ID {passenger_id} updated successfully.")
        except mysql.connector.Error as err:
            print(f"Error updating passenger: {err}")
        

    def delete_passenger(self, passenger_id):
        """Delete a passenger from the database."""
        try:
            self.cursor.execute('DELETE FROM passengers WHERE id=%s', (passenger_id,))
            self.conn.commit()
            print(f"Passenger ID {passenger_id} deleted successfully.")
        except mysql.connector.Error as err:
            print(f"Error deleting passenger: {err}")

    def search_passengers(self, first_name):
        """Search for passengers by name."""
        try:
            self.cursor.execute('SELECT * FROM passengers WHERE first_name LIKE %s', (f'%{first_name}%',))
            results = self.cursor.fetchall()
            if results:
                for passenger in results:
                    print(passenger)
            else:
                print("No passengers found with that name.")
        except mysql.connector.Error as err:
            print(f"Error searching passengers: {err}")
        

    def passenger_history(self, passenger_id):
        """View flight history for a specific passenger."""
        try:
            self.cursor.execute('''
        SELECT flights.flight_number, flights.departure, flights.arrival
        FROM passengers
        JOIN flights ON passengers.flight_id = flights.id
        WHERE passengers.id = %s''', (passenger_id,))
            history = self.cursor.fetchall()
            if history:
                for record in history:
                    print(record)
            else:
                print("No flight history found for this passenger.")
        except mysql.connector.Error as err:
            print(f"Error retrieving flight history for passenger ID {passenger_id}: {err}")
        

    def passenger_summary_report(self,):
        """Generate a summary report of all passengers."""
        self.cursor.execute('SELECT * FROM passengers')
        passengers = self.cursor.fetchall()
        report = "Passenger Summary Report:\n"
        report += "ID | Name | Age | Contact Number | Flight ID\n"
        report += "-" * 50 + "\n"
        for passenger in passengers:
            report += f"{passenger[0]} | {passenger[1]} | {passenger[2]} | {passenger[3]} | {passenger[4]}\n"
        print(report)

    def close(self):
        """Close the database connection."""
        self.cursor.close()
        self.conn.close()            




